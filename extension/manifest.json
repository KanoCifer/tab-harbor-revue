{
  "manifest_version": 3,
  "name": "Tab Harbor",
  "version": "2.0.0",
  "description": "Transform your browser tabs into a calm, organized workspace",
  "permissions": [
    "tabs",
    "storage",
    "search"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}